{
  "name": "html2pdf-pro",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm --filter @html2pdf-pro/web build",
    "dev": "pnpm --filter @html2pdf-pro/web dev",
    "dev:web": "pnpm --filter @html2pdf-pro/web dev",
    "dev:worker": "pnpm --filter @html2pdf-pro/worker dev",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --configLoader runner",
    "test:unit": "vitest run --configLoader runner --exclude \"**/*.integration.test.ts\" --exclude \"**/*.pw.test.ts\"",
    "test:integration": "vitest run --configLoader runner --passWithNoTests \"**/*.integration.test.ts\"",
    "test:playwright": "node ./scripts/run-playwright-tests.mjs",
    "test:runtime": "pnpm --filter @html2pdf-pro/worker health:check",
    "test:watch": "vitest --configLoader runner",
    "cleanup:run": "pnpm --filter @html2pdf-pro/worker cleanup:run",
    "cleanup:dry-run": "pnpm --filter @html2pdf-pro/worker cleanup:dry-run",
    "reconcile": "pnpm --filter @html2pdf-pro/worker reconcile",
    "health:check": "pnpm --filter @html2pdf-pro/worker health:check",
    "queue:check": "pnpm --filter @html2pdf-pro/queue queue:check",
    "worker:start": "pnpm --filter @html2pdf-pro/worker start",
    "db:migrate": "pnpm --filter @html2pdf-pro/database prisma:migrate",
    "db:generate": "pnpm --filter @html2pdf-pro/database prisma:generate",
    "db:validate": "pnpm --filter @html2pdf-pro/database prisma:validate"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.22.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.3",
    "eslint-config-prettier": "^10.1.1",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prisma": "^6.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}

{
  "compilerOptions": {
    "allowJs": false,
    "baseUrl": ".",
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "lib": ["dom", "dom.iterable", "es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "paths": {
      "@html2pdf-pro/config": ["packages/config/src/index.ts"],
      "@html2pdf-pro/conversions": ["packages/conversions/src/index.ts"],
      "@html2pdf-pro/database": ["packages/database/src/index.ts"],
      "@html2pdf-pro/pdf-engine": ["packages/pdf-engine/src/index.ts"],
      "@html2pdf-pro/queue": ["packages/queue/src/index.ts"],
      "@html2pdf-pro/storage": ["packages/storage/src/index.ts"],
      "@html2pdf-pro/web/*": ["apps/web/src/*"]
    }
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "eslint.config.mjs",
    "vitest.playwright.config.mjs"
  ],
  "exclude": ["node_modules"]
}

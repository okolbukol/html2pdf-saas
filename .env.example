NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=replace-with-google-client-id
AUTH_GOOGLE_SECRET=replace-with-google-client-secret
DATABASE_URL=postgresql://html2pdf:html2pdf@localhost:5432/html2pdf_pro?schema=public
REDIS_URL=redis://localhost:6379
APP_SECRET=replace-with-at-least-32-characters
INTERNAL_API_SECRET=replace-with-at-least-32-characters
STORAGE_DRIVER=local
LOCAL_STORAGE_PATH=./storage
HTML_SOURCE_STORAGE_PATH=./storage/sources
PDF_OUTPUT_STORAGE_PATH=./storage/outputs
CONVERSION_QUEUE_NAME=pdf-conversions
CONVERSION_JOB_ATTEMPTS=3
CONVERSION_JOB_TIMEOUT_MS=60000
CONVERSION_WORKER_CONCURRENCY=2
CONVERSION_RETENTION_HOURS=24
SOURCE_TTL_SECONDS=86400
OUTPUT_TTL_SECONDS=86400
HTML_SOURCE_TTL_SECONDS=86400
PDF_OUTPUT_TTL_SECONDS=86400
CLEANUP_BATCH_SIZE=100
CLEANUP_INTERVAL_SECONDS=3600
CLEANUP_DRY_RUN=true
MAX_HTML_BYTES=2000000
MAX_PDF_BYTES=10000000
HTML_MAX_BYTES=2000000
PDF_MAX_BYTES=10000000
NAVIGATION_TIMEOUT_MS=30000
PDF_GENERATION_TIMEOUT_MS=60000
MAX_REDIRECTS=5
MAX_NETWORK_REQUESTS=100
MAX_NETWORK_BYTES=20000000
MAX_TOTAL_NETWORK_BYTES=20000000
MAX_RESOURCE_BYTES=5000000
MAX_DOM_CONTENT_BYTES=5000000
WORKER_CONCURRENCY=2
WORKER_JOB_TIMEOUT_MS=60000
PLAYWRIGHT_JAVASCRIPT_ENABLED=true
